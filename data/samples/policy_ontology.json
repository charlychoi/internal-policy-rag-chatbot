        "action": "refuse"
      },
      {
        "risk_id": "discipline_evasion",
        "label": "징계/조사 회피",
        "patterns": ["징계 피하는 법", "증거 없애", "로그 삭제", "소명서 거짓", "조사 회피", "책임 안 지는 방법"],
        "action": "refuse"
      },
      {
        "risk_id": "privacy_exfiltration",
        "label": "개인정보 유출/무단 조회",
        "patterns": ["직원 주민번호", "연락처 목록", "인사평가 파일", "급여 정보", "몰래 조회", "개인정보 빼내", "동의 없이", "개인 이메일", "안 걸리", "개인정보 파일"],
        "action": "refuse"
      },
