# Open Notebook REST API
OPEN_NOTEBOOK_API_BASE=http://localhost:5055/api
OPEN_NOTEBOOK_PASSWORD=
OPEN_NOTEBOOK_NOTEBOOK_ID=
OPEN_NOTEBOOK_STRATEGY_MODEL=
OPEN_NOTEBOOK_ANSWER_MODEL=
OPEN_NOTEBOOK_FINAL_ANSWER_MODEL=

# Required by Open Notebook Docker Compose. Change before exposing to network.
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-long-random-secret
SURREAL_USER=root
SURREAL_PASSWORD=change-me

# Future Google Drive integration
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
